# .env - Environment Variables für HCC Plan Guacamole Multi-User Setup
# Diese Datei sollte NICHT in Git committed werden (.gitignore)

# ===========================================
# DATABASE CONFIGURATION
# ===========================================
POSTGRES_DB=hcc_plan_db
POSTGRES_USER=hcc_user
POSTGRES_PASSWORD=change_this_secure_password_123!
POSTGRES_PORT=5432

# Database URL für Python-Services
DATABASE_URL=postgresql://${POSTGRES_USER}:${POSTGRES_PASSWORD}@localhost:${POSTGRES_PORT}/${POSTGRES_DB}

# ===========================================
# GUACAMOLE CONFIGURATION  
# ===========================================
# Secret Key für JSON Authentication (generiere mit: openssl rand -hex 32)
GUACAMOLE_SECRET_KEY=4c0b569e4c96df157eee1b65dd0e4d41f8b7c9d2a3e4f5g6h7i8j9k0l1m2n3o4

# Guacamole Web-Interface Port
GUACAMOLE_PORT=8080

# Session Timeout (in Minuten, Standard: 4 Stunden)
GUACAMOLE_SESSION_TIMEOUT=240

# ===========================================
# AUTH SERVICE CONFIGURATION
# ===========================================
AUTH_SERVICE_PORT=8001
AUTH_SERVICE_HOST=0.0.0.0

# ===========================================
# LOGGING & DEBUGGING
# ===========================================  
# Guacamole Daemon Log Level (debug, info, warn, error)
GUACD_LOG_LEVEL=info

# Python Log Level
PYTHON_LOG_LEVEL=INFO

# ===========================================
# SESSION MANAGEMENT
# ===========================================
# Maximum gleichzeitige User-Sessions (für Testing)
MAX_CONCURRENT_SESSIONS=3

# Session Cleanup Timeout (Stunden)
SESSION_TIMEOUT_HOURS=4

# VNC Configuration
VNC_BASE_PORT=5900
DISPLAY_BASE_NUMBER=10

# ===========================================
# DEVELOPMENT SETTINGS
# ===========================================
# Set to 'development' für extended logging
ENVIRONMENT=production

# Enable/Disable specific features
ENABLE_SESSION_RECORDING=true
ENABLE_BRUTE_FORCE_PROTECTION=true

# ===========================================
# ANWEISUNGEN FÜR SETUP
# ===========================================
# 1. Kopiere diese Datei: cp .env.example .env
# 2. Ändere POSTGRES_PASSWORD zu einem sicheren Password
# 3. Generiere neuen GUACAMOLE_SECRET_KEY: openssl rand -hex 32
# 4. Starte Services: docker-compose up -d
# 5. Teste Authentication: curl http://localhost:8001/health
# 6. Öffne Guacamole: http://localhost:8080
