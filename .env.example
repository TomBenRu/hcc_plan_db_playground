# ===========================================
# DATABASE CONFIGURATION
# ===========================================
DATABASE_URL=postgresql://user:password@localhost:5432/hcc_plan

# ===========================================
# WEB-API CONFIGURATION (FastAPI)
# ===========================================
SECRET_KEY=change-me-to-a-random-secret
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7
DEBUG=true

# Basis-URL fuer absolute Links in transaktionalen Mails (Password-Reset,
# Email-Change, Verfuegbarkeits-Reminder). In Produktion auf die echte
# Public-URL setzen, sonst rendern Mail-Buttons mit `localhost`-Links.
BASE_URL=http://localhost:8000

# E-Mail-Verschluesselung: Master-Key fuer SMTP-Passwoerter in der DB.
# Generierung: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# SMTP-Server selbst (Host, Port, User, Passwort, Absender) wird ueber
# /admin/email-settings im laufenden System gepflegt — NICHT als Env-Var.
EMAIL_ENCRYPTION_KEY=

# ===========================================
# DESKTOP-CLIENT CONFIGURATION
# ===========================================
# 127.0.0.1 statt localhost: vermeidet IPv6-Fallback-Timeout auf Windows.
# In Produktion stattdessen die echte Server-URL eintragen.
DESKTOP_API_URL=http://127.0.0.1:8000
