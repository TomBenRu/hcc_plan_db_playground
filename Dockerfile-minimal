# Dockerfile-minimal - HCC Plan mit Openbox Minimal Window Manager (Option A)
# Basierend auf bewährtem Dockerfile, aber mit reduziertem Desktop-Overhead
FROM python:3.12-slim

LABEL maintainer="HCC Plan Development Team"
LABEL description="HCC Plan Application mit Openbox Minimal Window Manager für Direct GUI Access"

# System Dependencies + X11/VNC Support (MINIMAL)
RUN apt-get update && apt-get install -y \
    # Build tools
    gcc \
    g++ \
    make \
    # X11 und VNC Dependencies
    xvfb \
    x11vnc \
    tigervnc-standalone-server \
    tigervnc-common \
    # MINIMAL Window Manager (ersetzt xfce4 + xfce4-goodies)
    openbox \
    dbus-x11 \
    # Qt/GUI Dependencies (identisch zu funktionierendem Dockerfile)
    libqt5gui5 \
    libqt5widgets5 \
    libqt5core5a \
    libxcb-xinerama0 \
    libxcb-icccm4 \
    libxcb-image0 \
    libxcb-keysyms1 \
    libxcb-randr0 \
    libxcb-render-util0 \
    libxcb-cursor0 \
    # System utilities
    curl \
    wget \
    supervisor \
    && rm -rf /var/lib/apt/lists/*

# Set working directory
WORKDIR /app

# Copy requirements and install Python dependencies (identisch)
COPY requirements.txt .
RUN pip install --no-cache-dir --upgrade pip
RUN pip install --no-cache-dir -r requirements.txt

# Copy HCC Plan application (identisch)
COPY . /app/

# Create directories für VNC/Session management (identisch)
RUN mkdir -p /var/log/supervisor
RUN mkdir -p /tmp/.X11-unix
RUN mkdir -p /root/.vnc
RUN mkdir -p /recordings
RUN mkdir -p /root/.local/state/happy_code_company/hcc_plan/logs
RUN mkdir -p /root/.local/share/happy_code_company/hcc_plan/database

# Openbox-Konfiguration für Direct GUI
RUN mkdir -p /etc/openbox
RUN cat > /etc/openbox/rc.xml << 'EOF'
<?xml version="1.0" encoding="UTF-8"?>
<openbox_config xmlns="http://openbox.org/3.4/rc">
  <theme>
    <name>Clearlooks</name>
    <titleLayout>LIMC</titleLayout>
  </theme>
  <desktops>
    <number>1</number>
    <firstdesk>1</firstdesk>
  </desktops>
  <resize>
    <drawContents>yes</drawContents>
  </resize>
  <focus>
    <focusNew>yes</focusNew>
    <followMouse>no</followMouse>
    <focusLast>yes</focusLast>
    <underMouse>no</underMouse>
    <focusDelay>0</focusDelay>
    <raiseOnFocus>no</raiseOnFocus>
  </focus>
  <placement>
    <policy>Smart</policy>
  </placement>
  <!-- Application-spezifische Regeln für HCC Plan -->
  <applications>
    <!-- Hauptfenster maximieren -->
    <application title="HCC Plan*" class="python*">
      <maximized>yes</maximized>
      <focus>yes</focus>
    </application>
    <!-- Qt-Dialoge normal anzeigen -->
    <application type="dialog">
      <maximized>no</maximized>
      <focus>yes</focus>
      <decor>yes</decor>
    </application>
    <!-- QMessageBox normal anzeigen -->
    <application class="*" title="*Dialog*">
      <maximized>no</maximized>
      <focus>yes</focus>
    </application>
    <!-- Fallback: andere Fenster normal -->
    <application class="*">
      <maximized>no</maximized>
      <focus>yes</focus>
    </application>
  </applications>
</openbox_config>
EOF

# Openbox Autostart-Konfiguration (HCC Plan direkt starten)
RUN mkdir -p /etc/xdg/openbox
RUN cat > /etc/xdg/openbox/autostart << 'EOF'
#!/bin/bash
# HCC Plan Direct GUI Autostart
# Wartet kurz auf Window Manager, dann startet HCC Plan
(sleep 3 && cd /app && python main.py) &
EOF
RUN chmod +x /etc/xdg/openbox/autostart

# Supervisor configuration (MINIMAL - Openbox statt XFCE)
RUN cat > /etc/supervisor/conf.d/supervisord.conf << 'EOF'
[supervisord]
nodaemon=true
user=root
logfile=/var/log/supervisor/supervisord.log
pidfile=/var/run/supervisord.pid

[program:xvfb]
command=Xvfb %(ENV_DISPLAY)s -screen 0 %(ENV_RESOLUTION)s -ac +extension GLX +render -noreset
autostart=true
autorestart=true
stdout_logfile=/var/log/supervisor/xvfb.log
stderr_logfile=/var/log/supervisor/xvfb.log
priority=10

[program:x11vnc]
command=x11vnc -display %(ENV_DISPLAY)s -forever -usepw -shared -rfbport %(ENV_VNC_PORT)s -rfbauth /root/.vnc/passwd
autostart=true
autorestart=true
stdout_logfile=/var/log/supervisor/x11vnc.log
stderr_logfile=/var/log/supervisor/x11vnc.log
priority=20
depends_on=xvfb

[program:openbox]
command=openbox --config-file /etc/openbox/rc.xml
autostart=true
autorestart=true
stdout_logfile=/var/log/supervisor/openbox.log
stderr_logfile=/var/log/supervisor/openbox.log
environment=DISPLAY="%(ENV_DISPLAY)s"
priority=30
depends_on=xvfb

[program:hcc-plan-app]
command=python main.py
directory=/app
autostart=true
autorestart=true
stdout_logfile=/var/log/supervisor/hcc-plan.log
stderr_logfile=/var/log/supervisor/hcc-plan.log
environment=DISPLAY="%(ENV_DISPLAY)s",PYTHONPATH="/app",HCC_USER_ID="%(ENV_HCC_USER_ID)s",HCC_PROJECT_ID="%(ENV_HCC_PROJECT_ID)s"
priority=40
depends_on=openbox
user=root
EOF

# Environment Variables (identisch)
ENV DISPLAY=:1
ENV RESOLUTION=1920x1080x24
ENV VNC_PORT=5900
ENV VNC_PASSWORD=hcc-session
ENV PYTHONPATH=/app
ENV PYTHONUNBUFFERED=1
ENV QT_QPA_PLATFORM=xcb
ENV QT_X11_NO_MITSHM=1

# User-specific Environment (identisch)
ENV HCC_PROJECT_ID=""
ENV HCC_USER_ID=""  
ENV HCC_USER_ROLE=""

# Expose VNC port (identisch)
EXPOSE 5900

# Health check (identisch)
HEALTHCHECK --interval=30s --timeout=10s --start-period=60s --retries=3 \
    CMD pgrep -f "python.*main.py" && pgrep -f "Xvfb" && pgrep -f "x11vnc" || exit 1

# MINIMAL SOLUTION: Openbox + HCC Plan Direct Start
CMD ["/bin/bash", "-c", "echo '=== HCC Plan MINIMAL Container Starting ==='; mkdir -p /root/.vnc /tmp/.X11-unix /var/log/supervisor; chmod 1777 /tmp/.X11-unix; echo 'vncpass123' | vncpasswd -f > /root/.vnc/passwd; chmod 600 /root/.vnc/passwd; export HCC_USER_ID=${HCC_USER_ID:-anna}; export HCC_PROJECT_ID=${HCC_PROJECT_ID:-demo-project}; export DISPLAY=${DISPLAY:-:1}; export VNC_PORT=${VNC_PORT:-5900}; export RESOLUTION=${RESOLUTION:-1920x1080x24}; echo \"MINIMAL Mode - User: $HCC_USER_ID, Project: $HCC_PROJECT_ID\"; echo \"Direct GUI - Display: $DISPLAY, VNC Port: $VNC_PORT\"; exec /usr/bin/supervisord -c /etc/supervisor/conf.d/supervisord.conf"]
