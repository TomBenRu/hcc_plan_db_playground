<?xml version="1.0" encoding="UTF-8"?>
<!-- user-mapping-DIRECT.xml -->
<!-- Guacamole User-Mapping für Option A - Dual Access (Phase 2B + Direct GUI) -->
<user-mapping>
    
    <!-- Anna HCC Plan Session - SINGLE DIRECT ACCESS -->
    <authorize username="anna" password="cc03e747a6afbbcbf8be7668acfebee5" encoding="md5">
        
        <!-- Direct GUI Session (einzige Option) -->
        <connection name="HCC Plan">
            <protocol>vnc</protocol>
            <param name="hostname">hcc-anna-direct</param>
            <param name="port">5900</param>
            <param name="password">vncpass123</param>
            <param name="username">anna</param>
            
            <!-- Display Settings (optimiert für Direct GUI) -->
            <param name="color-depth">16</param>
            <param name="cursor">local</param>
            
            <!-- VNC Performance Optimization Parameters -->
            <param name="encoding">tight</param>
            <param name="compress-level">9</param>
            <param name="jpeg-quality">6</param>
            <param name="lossy">true</param>
            
            <!-- Session Recording -->
            <param name="recording-path">/recordings</param>
            <param name="create-recording-path">true</param>
            
            <!-- Performance Optimizations (DIRECT Mode) -->
            <param name="enable-wallpaper">false</param>
            <param name="enable-theming">false</param>
            <param name="enable-font-smoothing">false</param>
            <param name="enable-desktop-composition">false</param>
            <param name="enable-menu-animations">false</param>
            <param name="enable-full-window-drag">false</param>
            
            <!-- Clipboard Integration -->
            <param name="enable-sftp">false</param>
            <param name="clipboard-encoding">UTF-8</param>
            
            <!-- Direct GUI Optimizations -->
            <param name="resize-method">display-update</param>
            <param name="autoretry">5</param>
        </connection>
        
    </authorize>

    <!-- Test User für Debugging -->
    <authorize username="test" password="098f6bcd4621d373cade4e832627b4f6" encoding="md5">
        
        <!-- Direct GUI Session (einzige Option) -->
        <connection name="HCC Plan Test">
            <protocol>vnc</protocol>
            <param name="hostname">hcc-anna-direct</param>
            <param name="port">5900</param>
            <param name="password">vncpass123</param>
            <param name="color-depth">16</param>
            <param name="cursor">local</param>
        </connection>
        
    </authorize>

</user-mapping>

